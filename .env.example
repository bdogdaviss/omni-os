# Copy to .env.local and fill in. See README.md for what each does.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- AI providers (set at least one; set both for automatic failover) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional overrides:
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_FALLBACK_MODEL=gpt-4o-mini

# --- GitHub App integration (optional; needed for the GitHub features) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=
# Anthropic key handed to dispatched coding agents:
GITHUB_AGENT_ANTHROPIC_KEY=
# Must be "true" to write to real GitHub repos; leave unset for dry-run:
GITHUB_REAL_PUBLISHING_ENABLED=
